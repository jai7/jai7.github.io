---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';

const posts = (await getCollection('thoughts'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const byYear = posts.reduce<Record<string, typeof posts>>((acc, post) => {
  const year = post.data.date.getFullYear().toString();
  if (!acc[year]) acc[year] = [];
  acc[year].push(post);
  return acc;
}, {});

const years = Object.keys(byYear).sort((a, b) => Number(b) - Number(a));

function fmtDate(d: Date) {
  return d.toLocaleDateString('en-US', { month: 'short', day: '2-digit' });
}
---

<Base title="Thoughts">
  <div class="subpage">
    <div class="subpage-header">
      <div class="subpage-title">Thoughts</div>
      <div class="subpage-desc">Writing on distributed systems, data infrastructure and engineering craft.</div>
    </div>
    <ul class="ts-list">
      {years.map(year => (
        <>
          <li class="ts-year-divider">{year}</li>
          {byYear[year].map(post => (
            <li class="ts-item">
              <div class="ts-date">{fmtDate(post.data.date)}</div>
              <div class="ts-body">
                <a class="ts-link" href={`/thoughts/${post.id}`}>{post.data.title}</a>
                {post.data.tags.map(tag => <span class="ts-tag">{tag}</span>)}
                {post.data.readingTime && <div class="ts-meta">{post.data.readingTime}</div>}
              </div>
            </li>
          ))}
        </>
      ))}
    </ul>
  </div>
</Base>
