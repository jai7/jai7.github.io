---
import { getCollection, type CollectionEntry, render } from 'astro:content';
import Base from '../../layouts/Base.astro';

export async function getStaticPaths() {
  const posts = await getCollection('thoughts');
  return posts.map(post => ({
    params: { slug: post.id },
    props: { post },
  }));
}

interface Props {
  post: CollectionEntry<'thoughts'>;
}

const { post } = Astro.props;
const { Content } = await render(post);

function fmtFull(d: Date) {
  return d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
}
---

<Base title={post.data.title} description={post.data.description}>
  <div class="subpage">
    <div class="post-header">
      <div class="post-meta-line">
        <span class="post-date">{fmtFull(post.data.date)}</span>
        {post.data.readingTime && <span class="post-read">{post.data.readingTime}</span>}
      </div>
      <h1 class="post-title">{post.data.title}</h1>
      {post.data.tags.length > 0 && (
        <div class="post-tags">
          {post.data.tags.map(tag => <span class="ts-tag">{tag}</span>)}
        </div>
      )}
    </div>
    <div class="article-body">
      <Content />
    </div>
  </div>
</Base>

<style>
  .post-header { padding: 44px 0 28px; border-bottom: 1px solid var(--rule); margin-bottom: 32px; }
  .post-meta-line { display: flex; gap: 16px; align-items: center; margin-bottom: 14px; }
  .post-date { font-family: var(--mono); font-size: 11px; color: var(--muted); letter-spacing: 0.04em; }
  .post-read { font-family: var(--mono); font-size: 11px; color: var(--muted); }
  .post-title { font-family: var(--serif); font-size: clamp(24px, 5vw, 36px); font-weight: 400; line-height: 1.2; letter-spacing: -0.01em; margin-bottom: 14px; }
  .post-tags { margin-top: 4px; }
</style>
