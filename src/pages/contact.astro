---
import Base from '../layouts/Base.astro';
---

<Base title="Contact">
  <div class="subpage">
    <div class="subpage-header">
      <div class="subpage-title">Contact</div>
      <div class="subpage-desc">I'm generally reachable and reply within a few days.</div>
    </div>

    <p class="contact-prose">
      If you're working on something in the data or infra space and want to
      talk through a problem, I'm usually happy to help. Also open to interesting
      full-time roles and advisory conversations.
    </p>

    <ul class="contact-table">
      <li class="contact-row">
        <span class="contact-key">Email</span>
        <span class="contact-val"><a href="mailto:pjayakrishna19@gmail.com">pjayakrishna19@gmail.com</a></span>
      </li>
      <li class="contact-row">
        <span class="contact-key">GitHub</span>
        <span class="contact-val"><a href="https://github.com/jai7" target="_blank" rel="noopener">@jai7</a></span>
      </li>
      <li class="contact-row">
        <span class="contact-key">Twitter</span>
        <span class="contact-val"><a href="https://twitter.com/CodePhoenix19" target="_blank" rel="noopener">@CodePhoenix19</a></span>
      </li>
      <li class="contact-row">
        <span class="contact-key">LinkedIn</span>
        <span class="contact-val"><a href="https://www.linkedin.com/in/jayakrishna-parameswaramangalam-870732ba/" target="_blank" rel="noopener">jayakrishna-parameswaramangalam-870732ba</a></span>
      </li>
      <li class="contact-row">
        <span class="contact-key">Location</span>
        <span class="contact-val" style="color:var(--mid)">Seattle, WA</span>
      </li>
      <li class="contact-row">
        <span class="contact-key">Response</span>
        <span class="contact-val" style="color:var(--mid)">Usually within 48 hours</span>
      </li>
    </ul>
  </div>
</Base>
