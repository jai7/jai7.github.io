---
import { getCollection, type CollectionEntry, render } from 'astro:content';
import Base from '../../layouts/Base.astro';

export async function getStaticPaths() {
  const items = await getCollection('projects');
  return items.map(item => ({
    params: { slug: item.id },
    props: { item },
  }));
}

interface Props {
  item: CollectionEntry<'projects'>;
}

const { item } = Astro.props;
const { Content } = await render(item);

const statusLabel: Record<string, string> = {
  ongoing: 'Ongoing',
  shipped: 'Shipped',
  archived: 'Archived',
};
---

<Base title={item.data.title} description={item.data.description}>
  <div class="subpage">
    <div class="post-header">
      <div class="post-meta-line">
        <span class="post-date">{item.data.date.getFullYear()}</span>
        <span class="ts-tag">{statusLabel[item.data.status]}</span>
        {item.data.tags.map(tag => <span class="ts-tag">{tag}</span>)}
      </div>
      <h1 class="post-title">{item.data.title}</h1>
      {item.data.tech && <div class="post-tech">{item.data.tech}</div>}
    </div>

    <div class="article-body">
      <Content />
    </div>
  </div>
</Base>

<style>
  .post-header {
    padding: 44px 0 28px;
    border-bottom: 1px solid var(--rule);
    margin-bottom: 32px;
  }
  .post-meta-line {
    display: flex;
    gap: 8px;
    align-items: center;
    margin-bottom: 14px;
    flex-wrap: wrap;
  }
  .post-date {
    font-family: var(--mono);
    font-size: 11px;
    color: var(--muted);
    letter-spacing: 0.04em;
  }
  .post-title {
    font-family: var(--serif);
    font-size: clamp(24px, 5vw, 36px);
    font-weight: 400;
    line-height: 1.2;
    letter-spacing: -0.01em;
    margin-bottom: 10px;
  }
  .post-tech {
    font-family: var(--mono);
    font-size: 11px;
    color: var(--muted);
    margin-top: 6px;
  }
</style>
