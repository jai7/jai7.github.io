---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  isHome?: boolean;
}

const { title, description = 'Backend engineer working in ml, data and infra.', isHome = false } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{isHome ? 'Your Name' : `${title} — Your Name`}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body>
    <div class="shell">
      <div class="topbar">
        <a href="/" class="topbar-name">jayakrishnap.dev</a>
        {!isHome && <a href="/" class="topbar-back">← home</a>}
      </div>

      <main>
        <slot />
      </main>

      <footer class="footer">© {new Date().getFullYear()} Jayakrishna P</footer>
    </div>
  </body>
</html>
